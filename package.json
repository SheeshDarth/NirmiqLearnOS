{
  "name": "nirmiqcodesensei",
  "version": "1.0.0",
  "description": "Local-first learning OS: import a project, get a learning map, an 8-lens senior review, code-grounded DSA, and explain-back questions. 127.0.0.1 only, no telemetry.",
  "keywords": ["learning", "code-analysis", "mcp", "local-first", "education", "static-analysis"],
  "homepage": "https://github.com/SheeshDarth/NirmiqCodeSensei#readme",
  "repository": { "type": "git", "url": "git+https://github.com/SheeshDarth/NirmiqCodeSensei.git" },
  "bugs": { "url": "https://github.com/SheeshDarth/NirmiqCodeSensei/issues" },
  "license": "PolyForm-Noncommercial-1.0.0",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin/",
    "dist/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE.md",
    "SECURITY.md",
    "mcp-manifest.json"
  ],
  "bin": {
    "codesensei": "./bin/nirmiq.mjs",
    "nirmiqcodesensei": "./bin/nirmiq.mjs",
    "nirmiq": "./bin/nirmiq.mjs"
  },
  "scripts": {
    "dev": "next dev --turbopack --hostname 127.0.0.1",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "pack:standalone": "node scripts/pack-standalone.mjs",
    "build:mcp": "esbuild mcp-server/index.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/mcp-server.cjs --external:better-sqlite3 --tsconfig=tsconfig.json",
    "prepack": "npm run build && npm run pack:standalone && npm run build:mcp",
    "lint": "eslint . --ignore-pattern dist/ --ignore-pattern data/",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/import-pipeline.test.mts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "mcp": "tsx mcp-server/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.101.0",
    "@typescript-eslint/scope-manager": "^8.0.0",
    "@typescript-eslint/typescript-estree": "^8.0.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "3d-force-graph": "^1.80.0",
    "better-sqlite3": "^12.10.0",
    "drizzle-orm": "^0.45.2",
    "force-graph": "^1.51.4",
    "lucide-react": "^1.17.0",
    "next": "16.2.7",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "sharp": "^0.34.0"
  },
  "overrides": {
    "esbuild": "$esbuild"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "esbuild": "^0.28.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "postcss": "^8.4.31",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
