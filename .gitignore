# dependencies
node_modules/

# next
.next/
out/

# env
.env
.env.local
.env.*.local

# database/private local data
data/*.db
data/*.db-shm
data/*.db-wal
data/*.sqlite
*.db
*.db-shm
*.db-wal
*.sqlite

# license cache — contains key hash and email, never commit
data/license-cache.json

# imported project clones — local only, can be large
data/imported-projects/

# session tooling artifact (ECC cost/budget tracker)
data/.session-budget.json

# generated graphify map — regenerated on demand, not committed
CODEBASE_MAP.md

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
.dev-server.log

# system
.DS_Store
Thumbs.db

# temp
tmp/
temp/

# typescript
*.tsbuildinfo
next-env.d.ts

# build
build/

# distributable bundle — regenerated by `npm run pack:standalone` (prepack).
# Build output, not source: it is shipped in the npm tarball via package.json
# "files", never committed.
dist/
*.tgz

# vercel
.vercel
